{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Masking Report",
  "type": "object",
  "required": ["doctrine_rule", "events", "summary"],
  "properties": {
    "doctrine_rule": { "type": "string" },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["elements", "classification", "severity"],
        "properties": {
          "elements": { "type": "array", "items": { "type": "string" } },
          "frequency_range": { "type": "string" },
          "section": { "type": "string" },
          "depth_layers": { "type": "array" },
          "perceptual_roles": { "type": "array" },
          "classification": { "type": "string" },
          "severity": { "type": "string" },
          "reason": { "type": "string" },
          "recommendation": { "type": "string" }
        }
      }
    },
    "per_track_masking_risk": { "type": "object" },
    "summary": { "type": "object" }
  }
}
