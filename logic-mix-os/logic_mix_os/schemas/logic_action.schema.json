{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Logic Actions (bridge export)",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "track", "type", "plugin", "settings", "risk_class"],
    "properties": {
      "id": { "type": "string" },
      "track": { "type": "string" },
      "type": { "type": "string", "enum": ["insert_plugin", "set_send", "automation", "arrangement"] },
      "plugin": { "type": "string" },
      "settings": { "type": "string" },
      "risk_class": { "type": "integer" },
      "reason": { "type": "string" },
      "validation": { "type": "string" }
    }
  }
}
